{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bookroot.local/schemas/dictionary.schema.json",
  "title": "BookRoot Dictionary File",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "category", "description", "entries"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "category": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/entry" }
    }
  },
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "word", "slug", "aliases", "partOfSpeech", "domains", "tags",
        "level", "meaningZh", "definitionEn", "examples", "status", "version",
        "createdAt", "updatedAt"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/nonEmptyString" },
        "word": { "$ref": "#/$defs/nonEmptyString" },
        "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "aliases": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "partOfSpeech": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": { "enum": ["noun", "verb", "adjective", "adverb", "phrasal verb", "abbreviation", "phrase"] }
        },
        "domains": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true },
        "tags": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "level": { "enum": ["foundation", "intermediate", "advanced"] },
        "meaningZh": { "$ref": "#/$defs/nonEmptyString" },
        "definitionEn": { "$ref": "#/$defs/nonEmptyString" },
        "professionalMeaningZh": { "type": "string" },
        "whyThisWord": { "type": "string" },
        "origin": { "type": "string" },
        "wordParts": { "type": "array", "items": { "type": "object" } },
        "memoryTrick": { "type": "string" },
        "wordFamily": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "relatedWords": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "collocations": { "type": "array", "items": { "type": "object" } },
        "examples": { "type": "array", "minItems": 1, "items": { "type": "object" } },
        "comparisons": { "type": "array", "items": { "type": "object" } },
        "australianUsage": { "type": "object" },
        "pronunciation": { "type": "object" },
        "searchTerms": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "sources": { "type": "array", "items": { "type": "object" } },
        "status": { "enum": ["draft", "reviewed", "published"] },
        "version": { "type": "integer", "minimum": 1 },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
